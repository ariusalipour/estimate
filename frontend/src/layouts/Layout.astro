---
export interface Props {
  title?: string;
}

const { title = "EstiMate" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://unpkg.com/xterm@5.3.0/css/xterm.css" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #050805;
        --panel: #0b120b;
        --bar: #101710;
        --text: #8bff8b;
        --text-dim: rgba(139, 255, 139, 0.62);
        --line: rgba(139, 255, 139, 0.28);
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        min-height: 100%;
        background: radial-gradient(circle at top, #0d170d, var(--bg) 48%);
        color: var(--text);
        font-family: "Fira Code", "Cascadia Code", "JetBrains Mono", monospace;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background: repeating-linear-gradient(
          0deg,
          transparent 0,
          transparent 3px,
          rgba(139, 255, 139, 0.025) 3px,
          rgba(139, 255, 139, 0.025) 4px
        );
      }

      main {
        min-height: 100vh;
        width: 100vw;
      }

      .shell {
        width: 100vw;
        min-height: 100vh;
        border: 0;
        background: linear-gradient(180deg, rgba(13, 24, 13, 0.95), rgba(5, 8, 5, 0.98));
      }

      .shell-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-bottom: 1px solid var(--line);
        background: var(--bar);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-dim);
      }

      .shell-body {
        height: calc(100vh - 43px);
        padding: 10px;
        background: var(--panel);
      }

      @media (max-width: 720px) {
        .shell-body { height: calc(100vh - 43px); }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="shell">
        <div class="shell-bar">
          <span>estimate terminal</span>
          <span>astro + durable objects</span>
        </div>
        <div class="shell-body">
          <slot />
        </div>
      </section>
    </main>
  </body>
</html>
