---
export interface Props {
  title?: string;
}

const { title = "EstiMate" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://unpkg.com/xterm@5.3.0/css/xterm.css" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #050a16;
        --panel: #07101f;
        --panel-alt: #0d1730;
        --bar: #10204a;
        --text: #a8c8ff;
        --text-dim: rgba(168, 200, 255, 0.72);
        --line: rgba(116, 168, 255, 0.35);
        --accent: #f2f4ff;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        min-height: 100%;
        width: 100%;
        overflow: hidden;
        background:
          radial-gradient(circle at top, rgba(44, 83, 170, 0.28), transparent 24%),
          linear-gradient(180deg, #091228, var(--bg) 30%, #030712 100%);
        color: var(--text);
        font-family: "Perfect DOS VGA 437", "Courier New", "Lucida Console", monospace;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          repeating-linear-gradient(
            0deg,
            transparent 0,
            transparent 2px,
            rgba(255, 255, 255, 0.035) 2px,
            rgba(255, 255, 255, 0.035) 3px
          ),
          linear-gradient(90deg, rgba(90, 124, 255, 0.03), transparent 18%, transparent 82%, rgba(90, 124, 255, 0.03));
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(112, 168, 255, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(112, 168, 255, 0.04) 1px, transparent 1px);
        background-size: 100% 24px, 24px 100%;
        opacity: 0.28;
      }

      main {
        min-height: 100vh;
        width: 100vw;
        overflow: hidden;
      }

      .shell {
        width: 100vw;
        min-height: 100vh;
        border: 0;
        background: linear-gradient(180deg, rgba(10, 19, 40, 0.96), rgba(5, 10, 21, 0.98));
        overflow: hidden;
      }

      .shell-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        border-bottom: 2px solid var(--line);
        background: linear-gradient(180deg, #15316f, var(--bar));
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        text-shadow: 0 0 8px rgba(168, 200, 255, 0.35);
      }

      .shell-body {
        height: calc(100vh - 67px);
        padding: 10px;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(24, 44, 92, 0.1), transparent 80px),
          linear-gradient(180deg, var(--panel-alt), var(--panel));
      }

      .shell-body :global(.xterm) {
        height: 100%;
      }

      .shell-body :global(.xterm-viewport) {
        overflow: hidden !important;
      }

      .shell-body::before {
        content: "AMIBIOS(C) ESTIMATE 486DX2-SERIES  CMOS CHECKSUM OK   MEMORY TEST: 640K BASE, 7168K EXT";
        display: block;
        color: rgba(168, 200, 255, 0.52);
        font-size: 12px;
        letter-spacing: 0.08em;
        padding: 2px 4px 8px;
      }

      .shell-footer {
        height: 24px;
        display: grid;
        place-items: center;
        border-top: 1px solid var(--line);
        background: linear-gradient(180deg, #10204a, #0b1736);
        color: var(--accent);
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      @media (max-width: 720px) {
        .shell-body { height: calc(100vh - 67px); }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="shell">
        <div class="shell-bar">
          <span>EstiMate Planning Poker Terminal</span>
          <span></span>
        </div>
        <div class="shell-body">
          <slot />
        </div>
        <div class="shell-footer">A Mockachino Project</div>
      </section>
    </main>
  </body>
</html>
