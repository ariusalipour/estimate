---
import Layout from "../layouts/Layout.astro";
---

<Layout title="EstiMate — room">
  <div id="roomHeader" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
    <div>
      <span style="font-size:0.75rem;opacity:0.4">$ ROOM</span>
      <h1 style="font-size:1.2rem;margin-top:0.15rem">
        <span id="roomCode">---</span>
        <span id="connectionStatus" style="font-size:0.7rem;opacity:0.5;font-weight:400">connecting...</span>
      </h1>
    </div>
    <button id="leaveBtn" style="background:transparent;color:#33ff33;border:1px solid #33ff33;font-size:0.75rem;padding:0.4rem 1rem">[ Leave ]</button>
  </div>

  <hr class="divider" style="margin:0 0 1rem 0" />

  <div style="display:grid;grid-template-columns:1fr 220px;gap:1rem">
    <div>
      <div id="roundBanner" style="font-size:0.75rem;opacity:0.5;margin-bottom:0.75rem">&gt; <span id="roundInfo">no active round</span></div>

      <div id="cardGrid" style="display:flex;flex-wrap:wrap;gap:0.4rem;justify-content:center;margin-bottom:1rem">
        <span style="opacity:0.3;font-size:0.8rem">loading...</span>
      </div>

      <div id="hostControls" style="display:none;gap:0.4rem;justify-content:center;flex-wrap:wrap;margin-bottom:1rem">
        <button class="cmd-btn" id="revealBtn">[ reveal ]</button>
        <button class="cmd-btn" id="clearBtn">[ clear ]</button>
        <button class="cmd-btn" id="newRoundBtn">[ new round ]</button>
      </div>

      <div id="resultsArea" style="display:none;margin:1rem 0">
        <div style="font-size:0.75rem;opacity:0.4;margin-bottom:0.5rem">$ RESULTS</div>
        <div id="resultsGrid" style="display:flex;flex-wrap:wrap;gap:0.4rem"></div>
      </div>
    </div>

    <div style="border:1px solid #33ff33;border-color:#33ff33;padding:0.75rem">
      <div style="font-size:0.7rem;opacity:0.4;margin-bottom:0.5rem">$ PARTICIPANTS</div>
      <ul id="participantList" style="list-style:none;font-size:0.82rem">
        <li style="opacity:0.3">waiting...</li>
      </ul>
    </div>
  </div>
</Layout>

<script>
const params = new URLSearchParams(window.location.search);
const roomId = params.get("code") || "";
const myName = params.get("name") || "Anonymous";
const amHost = params.get("host") === "1";

let ws = null;
let state = null;
let myId = localStorage.getItem(`estimate_pid_${roomId}`);

document.getElementById("roomCode").textContent = roomId;

function connect() {
  const proto = location.protocol === "https:" ? "wss:" : "ws:";
  const wsUrl = `${proto}//${location.host}/ws/${roomId}?name=${encodeURIComponent(myName)}${myId ? `&pid=${myId}` : ""}`;
  ws = new WebSocket(wsUrl);

  ws.onopen = () => {
    const el = document.getElementById("connectionStatus");
    el.textContent = "connected";
    el.style.opacity = "0.6";
  };

  ws.onmessage = (event) => handleMessage(JSON.parse(event.data));

  ws.onclose = () => {
    const el = document.getElementById("connectionStatus");
    el.textContent = "reconnecting...";
    el.style.opacity = "0.4";
    setTimeout(connect, 2000);
  };
}

function handleMessage(msg) {
  switch (msg.type) {
    case "room_state": {
      state = msg.state;
      if (!myId) {
        myId = state.participants[state.participants.length - 1]?.id;
        if (myId) localStorage.setItem(`estimate_pid_${roomId}`, myId);
      }
      renderParticipants();
      renderCards();
      renderRoundInfo();
      renderHostControls();
      break;
    }
    case "participant_joined": {
      state?.participants.push(msg.participant);
      renderParticipants();
      break;
    }
    case "participant_left": {
      if (state) state.participants = state.participants.filter(p => p.id !== msg.participantId);
      renderParticipants();
      break;
    }
    case "participant_updated": {
      const p = state?.participants.find(x => x.id === msg.participant.id);
      if (p) Object.assign(p, msg.participant);
      renderParticipants();
      break;
    }
    case "vote_cast": {
      document.querySelectorAll(".vote-card").forEach(el => {
        if (el.dataset.pid === msg.participantId) el.classList.add("voted");
      });
      renderParticipants();
      break;
    }
    case "votes_revealed":
      renderResults(msg.votes);
      break;
    case "new_round":
      if (state) state.currentRound = msg.round;
      document.getElementById("resultsArea").style.display = "none";
      renderCards();
      renderRoundInfo();
      break;
    case "round_cleared":
      if (state) state.currentRound = null;
      document.getElementById("resultsArea").style.display = "none";
      renderCards();
      renderRoundInfo();
      break;
    case "host_changed":
      if (state) state.hostId = msg.hostId;
      renderHostControls();
      renderParticipants();
      break;
    case "settings_changed":
      if (state) state.numbers = msg.numbers;
      renderCards();
      break;
    case "error":
      alert("error: " + msg.message);
      break;
  }
}

function send(msg) { ws?.send(JSON.stringify(msg)); }

function renderParticipants() {
  if (!state) return;
  const list = document.getElementById("participantList");
  list.innerHTML = state.participants.map(p => `
    <li style="display:flex;align-items:center;gap:0.5rem;padding:0.3rem 0;
      ${p.isHost ? "color:#33ff33;opacity:1" : "opacity:0.7"}">
      <span style="font-size:0.65rem">${p.isHost ? "&#9830;" : "&#9679;"}</span>
      ${p.name}
      <span style="font-size:0.6rem;opacity:0.4">${p.isHost ? "(HOST)" : ""}</span>
    </li>
  `).join("");
}

function renderCards() {
  if (!state) return;
  const grid = document.getElementById("cardGrid");
  grid.innerHTML = state.numbers.map(n => `
    <button class="vote-card" data-value="${n}" style="
      width:64px;height:88px;background:#0a0a0a;border:1px solid #33ff33;
      color:#33ff33;font-family:inherit;font-size:1.1rem;font-weight:600;cursor:pointer;
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      transition:all 0.1s;opacity:0.8;
    ">${n}</button>
  `).join("");

  const round = state.currentRound;
  const votedPids = round && round.status === "voting"
    ? new Set(
        state.participants
          .filter(p => document.querySelector(`[data-pid="${p.id}"].voted`))
          .map(p => p.id)
      )
    : new Set();

  grid.querySelectorAll(".vote-card").forEach(btn => {
    btn.addEventListener("click", () => {
      if (!state?.currentRound || state.currentRound.status !== "voting") return;
      const value = btn.dataset.value;
      send({ type: "vote", value });
      btn.dataset.pid = myId;
      grid.querySelectorAll(".vote-card").forEach(b => b.classList.remove("selected"));
      btn.classList.add("selected");
    });
  });
}

function renderRoundInfo() {
  const el = document.getElementById("roundInfo");
  if (state?.currentRound) {
    const r = state.currentRound;
    el.textContent = `round ${r.number}${r.topic ? ` — ${r.topic}` : ""} — ${r.status}`;
  } else {
    el.textContent = "no active round. host: [new round]";
  }
}

function renderHostControls() {
  const el = document.getElementById("hostControls");
  el.style.display = (state && state.hostId === myId) ? "flex" : "none";
}

function renderResults(votes) {
  const area = document.getElementById("resultsArea");
  area.style.display = "block";
  const grid = document.getElementById("resultsGrid");
  grid.innerHTML = state.participants.map(p => `
    <div style="
      border:1px solid #33ff33;padding:0.5rem 0.75rem;text-align:center;min-width:70px;
      background:#0a0a0a;
    ">
      <div style="font-size:1.3rem;font-weight:600">${votes[p.id] ?? "—"}</div>
      <div style="font-size:0.6rem;opacity:0.5;margin-top:0.2rem">${p.name}</div>
    </div>
  `).join("");
}

connect();

document.getElementById("revealBtn")?.addEventListener("click", () => send({ type: "reveal" }));
document.getElementById("clearBtn")?.addEventListener("click", () => send({ type: "clear_round" }));
document.getElementById("newRoundBtn")?.addEventListener("click", () => {
  const topic = prompt("round topic:") || "";
  send({ type: "new_round", topic });
});
document.getElementById("leaveBtn")?.addEventListener("click", () => {
  ws?.close();
  window.location.href = "/";
});
</script>

<style>
  .vote-card:hover {
    background: #1a1a1a !important;
    box-shadow: 0 0 8px rgba(51,255,51,0.2);
  }
  .vote-card.selected {
    background: #1a3a1a !important;
    border-color: #33ff33;
    box-shadow: 0 0 12px rgba(51,255,51,0.3);
    opacity: 1;
  }
  .cmd-btn {
    background: transparent !important;
    color: #33ff33 !important;
    border: 1px solid #33ff33 !important;
    font-size: 0.75rem !important;
    padding: 0.35rem 0.85rem !important;
  }
  .cmd-btn:hover {
    background: #33ff33 !important;
    color: #0a0a0a !important;
  }
</style>
